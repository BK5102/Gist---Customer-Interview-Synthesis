ANTHROPIC_API_KEY=sk-ant-...
CORS_ORIGINS=http://localhost:3000  # Comma-separated; set to your Vercel URL in prod
STORE_TRANSCRIPTS=false             # Keep false in prod: raw transcripts are processed in-memory only, not saved
ENABLE_SYNTH_CACHE=false            # Keep false in prod: avoids writing quote-bearing cache files
STORE_PLAINTEXT_SYNTHESES=false     # Keep false in prod: synthesis markdown can contain sensitive quotes
# Phase 1 transcription — set ONE of these. Groq is free + faster + higher
# quality (whisper-large-v3); OpenAI is paid (whisper-1, $0.006/min).
GROQ_API_KEY=gsk_...             # https://console.groq.com — preferred
OPENAI_API_KEY=sk-...            # https://platform.openai.com — fallback
SUPABASE_URL=https://xxx.supabase.co  # Phase 2
SUPABASE_ANON_KEY=...            # Phase 2
SUPABASE_SERVICE_ROLE_KEY=...    # Phase 2 (backend only — never expose to frontend)
SUPABASE_JWT_SECRET=...          # Phase 2 — legacy HS256 secret. Required if your
                                 # project uses legacy anon/service_role keys (the
                                 # default for older projects). Skip if your project
                                 # uses the new publishable/secret keys with JWKS.
# Phase 3 — set EITHER OAuth (Public integration, prod) OR internal token
# (Internal integration, solo dev). Internal sidesteps Notion's marketplace-
# profile requirements but only sees pages explicitly shared with the
# integration via the Notion ⋯ → Connections menu.
NOTION_CLIENT_ID=...             # Public integration OAuth client ID
NOTION_CLIENT_SECRET=...         # Public integration OAuth secret
NOTION_INTERNAL_TOKEN=secret_... # OR: Internal Integration Secret (dev shortcut)
NOTION_REDIRECT_URI=http://localhost:8000/notion/callback  # Must match Notion integration redirect URI
FRONTEND_SETTINGS_URL=http://localhost:3000/settings
